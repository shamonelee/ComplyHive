{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"customTemplates": [
		{
			"name": "blank",
			"postTypes": [
				"page",
				"post"
			],
			"title": "Blank Canvas"
		},
		{
			"name": "page-insights",
			"postTypes": [
				"page"
			],
			"title": "Insights Archive"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#111111",
					"name": "Ink",
					"slug": "ink"
				},
				{
					"color": "#0a0a0a",
					"name": "Ink Deep",
					"slug": "ink-deep"
				},
				{
					"color": "#2C3645",
					"name": "Slate",
					"slug": "slate"
				},
				{
					"color": "#B8955A",
					"name": "Gold",
					"slug": "gold"
				},
				{
					"color": "#d4af6a",
					"name": "Gold Light",
					"slug": "gold-light"
				},
				{
					"color": "#FAF7F2",
					"name": "Cream",
					"slug": "cream"
				},
				{
					"color": "#F3EDE3",
					"name": "Parchment",
					"slug": "parchment"
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#6B7C8F",
					"name": "Mid Grey",
					"slug": "mid-grey"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Exo 2', sans-serif",
					"name": "Heading",
					"slug": "heading"
				},
				{
					"fontFamily": "'Figtree', sans-serif",
					"name": "Body",
					"slug": "body"
				},
				{
					"fontFamily": "'DM Mono', monospace",
					"name": "Mono",
					"slug": "mono"
				}
			]
		},
		"useRootPaddingAwareAlignments": false
	},
	"styles": {
		"blocks": {
			"core/html": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			},
			"core/post-content": {
				"spacing": {
					"padding": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			}
		},
		"color": {
			"background": "#111111",
			"text": "#FAF7F2"
		},
		"css": "",
		"elements": {
			"link": {
				"color": {
					"text": "#B8955A"
				}
			}
		},
		"spacing": {
			"blockGap": "0",
			"margin": {
				"bottom": "0",
				"top": "0"
			},
			"padding": {
				"bottom": "0",
				"left": "0",
				"right": "0",
				"top": "0"
			}
		},
		"typography": {
			"fontFamily": "'Figtree', sans-serif",
			"fontSize": "1rem",
			"lineHeight": "1.7"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"version": 3
}